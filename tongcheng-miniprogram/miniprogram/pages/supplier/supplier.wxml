<view class="page-supplier">
  <!-- 轮播：约屏幕 1/6 高度 -->
  <swiper
    class="supplier-swiper"
    style="height: {{bannerHeight}}px;"
    indicator-dots="{{true}}"
    autoplay="{{true}}"
    interval="{{4000}}"
    circular="{{true}}"
    indicator-color="rgba(255,255,255,0.5)"
    indicator-active-color="#ffffff"
  >
    <swiper-item wx:for="{{banners}}" wx:key="*this">
      <image class="supplier-swiper__img" style="height: {{bannerHeight}}px;" src="{{item}}" mode="aspectFill" />
    </swiper-item>
  </swiper>

  <!-- 商圈公告 -->
  <view class="notice-bar flex-row">
    <text class="notice-bar__tag">商圈公告</text>
    <swiper class="notice-swiper" vertical autoplay circular interval="{{3000}}" display-multiple-items="{{1}}">
      <swiper-item wx:for="{{vendorNotices}}" wx:key="*this">
        <text class="notice-swiper__text">欢迎入驻：{{item}}</text>
      </swiper-item>
    </swiper>
  </view>

  <!-- 四大模块 -->
  <view class="module-panel card">
    <view
      class="module-cell {{item.link ? 'module-cell--join' : ''}} {{activeModuleId === item.id ? 'module-cell--active' : ''}}"
      wx:for="{{modules}}"
      wx:key="id"
      data-id="{{item.id}}"
      data-link="{{item.link}}"
      bindtap="onModuleTap"
    >
      <text class="module-cell__icon">{{item.icon}}</text>
      <text class="module-cell__name">{{item.name}}</text>
      <text class="module-cell__badge" wx:if="{{item.link}}">入驻 ›</text>
    </view>
  </view>

  <!-- 标签 -->
  <view class="tabs-bar">
    <view
      class="tab-item {{activeTab === item.id ? 'tab-item--active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="onTabChange"
    >
      {{item.name}}
    </view>
  </view>

  <!-- 商家列表 -->
  <view class="merchant-list">
    <view class="merchant-card card" wx:for="{{merchantList}}" wx:key="id" bindtap="onMerchantTap" data-id="{{item.id}}">
      <view class="merchant-card__head flex-between">
        <text class="merchant-card__name">{{item.shopName}}</text>
        <text class="merchant-card__tag">{{item.categoryName}}</text>
      </view>
      <text class="merchant-card__intro">{{item.intro}}</text>
      <view class="merchant-card__foot flex-between">
        <text class="text-muted">📞 {{item.phone}}</text>
        <text class="text-muted" wx:if="{{item.distance}}">{{item.distance}}</text>
      </view>
    </view>
    <view wx:if="{{!merchantList.length}}" class="empty">暂无商家，欢迎入驻</view>
  </view>
</view>
