.page-membership {
  min-height: 100vh;
  padding: 24rpx;
  background: linear-gradient(180deg, #e3f2fd 0%, #f5f5f5 280rpx);
  box-sizing: border-box;
}

.vip-header {
  background: linear-gradient(135deg, #d4a574, #c4956a);
  border-radius: 16rpx;
  padding: 32rpx 28rpx;
  color: #5d4037;
  margin-bottom: 24rpx;
}

.vip-header--empty {
  background: #ffffff;
  color: #666666;
  font-size: 28rpx;
  text-align: center;
}

.vip-header__title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.vip-header__expire,
.vip-header__amount {
  display: block;
  font-size: 26rpx;
  margin-top: 8rpx;
}

.plan-list {
  margin-bottom: 24rpx;
}

.plan-card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid transparent;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.plan-card--active {
  border-color: #2d7dd2;
  background-color: #f0f8ff;
}

.plan-card__name {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
}

.plan-card__price {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #e54d42;
  margin: 12rpx 0;
}

.plan-card__desc {
  font-size: 24rpx;
  color: #999999;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.tips__title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.tips__line {
  display: block;
  font-size: 24rpx;
  color: #666666;
  line-height: 1.8;
}

.buy-btn {
  margin-top: 32rpx;
  background-color: #2d7dd2;
  border-radius: 12rpx;
}
