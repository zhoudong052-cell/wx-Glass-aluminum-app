.page-mine {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 32rpx;
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-between {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

/* 蓝色头部 */
.header {
  background: linear-gradient(135deg, #4a9ff5 0%, #2d7dd2 50%, #1e6bb8 100%);
  padding: 0 24rpx 40rpx;
  position: relative;
  overflow: hidden;
}

.header::after {
  content: '';
  position: absolute;
  top: -40%;
  right: -20%;
  width: 80%;
  height: 160%;
  background: repeating-linear-gradient(
    -25deg,
    transparent,
    transparent 20rpx,
    rgba(255, 255, 255, 0.06) 20rpx,
    rgba(255, 255, 255, 0.06) 40rpx
  );
  pointer-events: none;
}

.header-bar {
  height: 88rpx;
  position: relative;
  z-index: 1;
}

.header-icon {
  font-size: 40rpx;
  color: #ffffff;
  padding: 8rpx;
}

.header-main {
  position: relative;
  z-index: 1;
  align-items: flex-start;
}

.user-block {
  flex: 1;
  min-width: 0;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.85);
  background-color: #ffffff;
  flex-shrink: 0;
}

.user-text {
  margin-left: 20rpx;
  flex: 1;
  min-width: 0;
}

.nickname {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.profile-link {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

.member-card {
  background: linear-gradient(145deg, #d4a574 0%, #c4956a 100%);
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  transform: rotate(6deg);
  box-shadow: 0 8rpx 16rpx rgba(0, 0, 0, 0.15);
  flex-shrink: 0;
  margin-left: 16rpx;
  margin-top: 8rpx;
}

.member-card__title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #5d4037;
}

.member-card__sub {
  display: block;
  font-size: 20rpx;
  color: #6d4c41;
  margin-top: 4rpx;
}

.login-btn {
  margin-top: 16rpx;
  background-color: rgba(255, 255, 255, 0.95);
  color: #2d7dd2;
  position: relative;
  z-index: 1;
}

/* 统计栏 */
.card {
  background-color: #ffffff;
  margin: 0 24rpx 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.stats-row {
  display: flex;
  flex-direction: row;
  margin-top: -24rpx;
  position: relative;
  z-index: 2;
  padding: 28rpx 0;
}

.stats-cell {
  flex: 1;
  text-align: center;
}

.stats-cell__num {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #e54d42;
  margin-bottom: 8rpx;
}

.stats-cell__label {
  font-size: 26rpx;
  color: #333333;
}

/* 区块 */
.section {
  padding: 24rpx 16rpx 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  padding: 0 8rpx 20rpx;
}

.icon-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
}

.icon-grid__item {
  width: 33.33%;
  text-align: center;
  padding: 16rpx 8rpx 24rpx;
  box-sizing: border-box;
}

.icon-grid--4 .icon-grid__item {
  width: 25%;
}

.icon-grid__icon {
  width: 88rpx;
  height: 88rpx;
  line-height: 88rpx;
  margin: 0 auto 12rpx;
  border-radius: 20rpx;
  font-size: 40rpx;
}

.icon-grid__name {
  font-size: 24rpx;
  color: #333333;
}

.safe-bottom {
  height: env(safe-area-inset-bottom);
}
