.page-join {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  background-color: #f5f5f5;
  box-sizing: border-box;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 8rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

.field-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.field-row:last-child {
  border-bottom: none;
}

.field-row--picker {
  border-bottom: none;
}

.field-label {
  font-size: 28rpx;
  color: #333333;
  width: 160rpx;
  flex-shrink: 0;
}

.field-required {
  color: #e54d42;
  margin-right: 8rpx;
}

.field-input {
  flex: 1;
  font-size: 28rpx;
}

.field-picker-value {
  flex: 1;
  display: flex;
  flex-direction: row;
  justify-content: flex-end;
  align-items: center;
  font-size: 28rpx;
  color: #333333;
}

.arrow {
  color: #999999;
  font-size: 22rpx;
  margin-left: 8rpx;
}

.block-label {
  font-size: 28rpx;
  color: #333333;
  font-weight: 600;
  padding: 24rpx 0 16rpx;
}

.intro-input {
  width: 100%;
  min-height: 200rpx;
  font-size: 28rpx;
  padding-bottom: 24rpx;
  box-sizing: border-box;
}

.text-muted {
  font-size: 24rpx;
  color: #999999;
  font-weight: normal;
}

.upload-grid {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  padding-bottom: 24rpx;
}

.upload-item,
.upload-add {
  width: 200rpx;
  height: 200rpx;
  margin-right: 16rpx;
  margin-bottom: 16rpx;
  border-radius: 12rpx;
  position: relative;
}

.upload-img {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.upload-add {
  background-color: #f8f8f8;
  border: 1rpx dashed #cccccc;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-add__icon {
  font-size: 48rpx;
  color: #cccccc;
  line-height: 1;
}

.upload-add__text {
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.upload-del {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 36rpx;
  text-align: center;
  background-color: rgba(0, 0, 0, 0.55);
  color: #ffffff;
  border-radius: 50%;
  font-size: 28rpx;
}

.submit-btn {
  background-color: #e54d42;
  border-radius: 12rpx;
  margin-top: 16rpx;
}
