page {
  background-color: #f5f5f5;
  color: #333333;
  font-size: 28rpx;
  line-height: 1.5;
  box-sizing: border-box;
}

.container {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-between {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.text-muted {
  color: #999999;
  font-size: 24rpx;
}

.btn-primary {
  background-color: #07c160;
  color: #ffffff;
  border-radius: 8rpx;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}
