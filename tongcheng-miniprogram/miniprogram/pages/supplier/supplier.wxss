.page-supplier {
  min-height: 100vh;
  background-color: #f5f5f5;
  padding-bottom: 24rpx;
}

.supplier-swiper {
  width: 100%;
  background-color: #eeeeee;
}

.supplier-swiper__img {
  width: 100%;
  display: block;
}

.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

/* 商圈公告 */
.notice-bar {
  background-color: #fff8f0;
  padding: 16rpx 24rpx;
  align-items: center;
}

.notice-bar__tag {
  color: #e54d42;
  font-size: 26rpx;
  font-weight: 600;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.notice-swiper {
  flex: 1;
  height: 40rpx;
}

.notice-swiper__text {
  font-size: 26rpx;
  color: #576b95;
  line-height: 40rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  margin: 16rpx 24rpx 0;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.04);
}

/* 四大模块 */
.module-panel {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  padding: 16rpx 8rpx;
}

.module-cell {
  width: 25%;
  text-align: center;
  padding: 16rpx 8rpx;
  box-sizing: border-box;
}

.module-cell__icon {
  display: block;
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.module-cell__name {
  font-size: 24rpx;
  color: #333333;
}

.module-cell__badge {
  display: block;
  font-size: 20rpx;
  color: #e54d42;
  margin-top: 4rpx;
}

.module-cell--active .module-cell__name {
  color: #1989fa;
  font-weight: 600;
}

.module-cell--join .module-cell__icon {
  background-color: #fff0ee;
  width: 72rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 50%;
  margin: 0 auto 8rpx;
  border: 2rpx solid #e54d42;
}

/* 标签 */
.tabs-bar {
  display: flex;
  flex-direction: row;
  background-color: #ffffff;
  margin-top: 16rpx;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.tab-item {
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  color: #666666;
}

.tab-item--active {
  color: #1989fa;
  font-weight: 600;
  border-bottom: 4rpx solid #1989fa;
}

/* 商家列表 */
.merchant-list {
  padding: 16rpx 24rpx;
}

.merchant-card {
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.merchant-card__head {
  margin-bottom: 12rpx;
}

.merchant-card__name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.merchant-card__tag {
  font-size: 22rpx;
  color: #e54d42;
  background-color: #fff0ee;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.merchant-card__intro {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.5;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.merchant-card__foot {
  font-size: 24rpx;
}

.flex-between {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

.text-muted {
  color: #999999;
}

.empty {
  text-align: center;
  color: #999999;
  padding: 60rpx 0;
}
