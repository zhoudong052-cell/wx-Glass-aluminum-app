.page-index {
  padding-bottom: 24rpx;
  background-color: #f5f5f5;
}

/* 红色页头 */
.header-red {
  background: linear-gradient(180deg, #e54d42 0%, #d73c32 100%);
  padding: 16rpx 24rpx 20rpx;
}

.header-red__inner {
  align-items: center;
}

.header-logo {
  width: 64rpx;
  height: 64rpx;
  border-radius: 8rpx;
  background-color: rgba(255, 255, 255, 0.9);
  flex-shrink: 0;
}

.header-search {
  flex: 1;
  margin: 0 16rpx;
  background-color: #ffffff;
  border-radius: 40rpx;
  padding: 12rpx 24rpx;
  height: 64rpx;
  box-sizing: border-box;
}

.search-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  color: #333333;
}

.search-placeholder {
  color: #bbbbbb;
}

.header-msg {
  font-size: 40rpx;
  flex-shrink: 0;
  padding: 0 4rpx;
}

/* 轮播 */
.banner-swiper {
  width: 100%;
  height: 320rpx;
  background-color: #eeeeee;
}

.banner-swiper__img {
  width: 100%;
  height: 320rpx;
  display: block;
}

/* 数据统计栏 */
.stats-bar {
  background-color: #ffffff;
  padding: 20rpx 24rpx;
  align-items: center;
  border-bottom: 1rpx solid #f0f0f0;
}

.stats-bar__speaker {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.stats-bar__items {
  flex: 1;
  justify-content: space-around;
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-item__label {
  display: block;
  font-size: 24rpx;
  color: #666666;
  margin-bottom: 4rpx;
}

.stat-item__value {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #e54d42;
}

.stats-bar__help {
  font-size: 26rpx;
  color: #576b95;
  flex-shrink: 0;
  margin-left: 12rpx;
  padding-left: 16rpx;
  border-left: 1rpx solid #eeeeee;
}

/* 分类宫格 */
.category-panel {
  margin: 16rpx 24rpx 0;
  padding: 24rpx 12rpx 8rpx;
  border-radius: 16rpx;
}

.category-grid {
  display: flex;
  flex-wrap: wrap;
}

.category-grid__item {
  width: 25%;
  text-align: center;
  margin-bottom: 24rpx;
}

.category-grid__icon {
  width: 88rpx;
  height: 88rpx;
  line-height: 88rpx;
  margin: 0 auto 8rpx;
  font-size: 40rpx;
  background-color: #f8f8f8;
  border-radius: 50%;
}

.category-grid__name {
  font-size: 24rpx;
  color: #333333;
}

/* 公告 */
.notice-bar {
  margin: 16rpx 24rpx 0;
  background-color: #fff8f0;
  border-radius: 8rpx;
  padding: 16rpx 20rpx;
  align-items: center;
}

.notice-bar__tag {
  color: #e54d42;
  font-size: 26rpx;
  font-weight: 600;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.notice-bar__text {
  font-size: 24rpx;
  color: #576b95;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

/* 列表 Tab */
.feed-section {
  margin-top: 16rpx;
}

.feed-tabs {
  white-space: nowrap;
  background-color: #ffffff;
  padding: 0 16rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.feed-tab {
  display: inline-block;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: #666666;
}

.feed-tab--active {
  color: #1989fa;
  font-weight: 600;
  border-bottom: 4rpx solid #1989fa;
}

.feed-list {
  padding: 16rpx 24rpx 0;
}

.empty {
  text-align: center;
  color: #999999;
  padding: 80rpx 0;
}
