.page-publish {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  background-color: #f5f5f5;
  box-sizing: border-box;
}

.card {
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.section-head {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
}

.section-required {
  font-size: 24rpx;
  color: #e54d42;
  margin-left: 8rpx;
}

.text-muted {
  color: #999999;
  font-size: 24rpx;
}

.flex-between {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
}

/* 下拉选择行 */
.picker-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  background-color: #f8f8f8;
  border-radius: 12rpx;
  padding: 28rpx 24rpx;
  border: 1rpx solid #eeeeee;
}

.picker-row__label {
  font-size: 28rpx;
  color: #666666;
  width: 160rpx;
  flex-shrink: 0;
}

.picker-row__value {
  flex: 1;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: flex-end;
}

.picker-row__text {
  font-size: 28rpx;
  color: #333333;
  font-weight: 500;
  text-align: right;
  flex: 1;
}

.picker-row__placeholder {
  font-size: 28rpx;
  color: #bbbbbb;
  text-align: right;
  flex: 1;
}

.picker-row__arrow {
  font-size: 22rpx;
  color: #999999;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.picker-hint {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
}

/* 发布内容 */
.content-input {
  width: 100%;
  min-height: 240rpx;
  font-size: 28rpx;
  line-height: 1.6;
  color: #333333;
  box-sizing: border-box;
}

.char-count {
  display: block;
  text-align: right;
  margin-top: 12rpx;
}

/* 联系人 */
.field-row {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 20rpx 0;
}

.field-row--border {
  border-top: 1rpx solid #f0f0f0;
}

.field-label {
  width: 120rpx;
  font-size: 28rpx;
  color: #666666;
  flex-shrink: 0;
}

.field-input {
  flex: 1;
  font-size: 28rpx;
}

/* 置顶 */
.pin-row {
  align-items: center;
}

.pin-desc {
  display: block;
  margin-top: 6rpx;
}

.pin-qr-block {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #f0f0f0;
  text-align: center;
}

.pin-qr-tip {
  font-size: 26rpx;
  color: #e54d42;
  margin-bottom: 20rpx;
}

.pin-qr-image {
  width: 320rpx;
  height: 320rpx;
  margin: 0 auto 20rpx;
  background-color: #f8f8f8;
  border-radius: 12rpx;
}

.scan-btn {
  background-color: #e54d42;
  color: #ffffff;
  border: none;
  margin-bottom: 12rpx;
}

.pin-scan-ok {
  font-size: 26rpx;
  color: #07c160;
}

.submit-btn {
  margin-top: 8rpx;
  background-color: #e54d42;
  border-radius: 12rpx;
}

.submit-btn[disabled] {
  opacity: 0.6;
}

/* 底部提示 */
.footer-notice {
  margin-top: 32rpx;
  padding: 24rpx;
  background-color: #fff8e6;
  border-radius: 12rpx;
  border-left: 6rpx solid #ff9800;
}

.footer-notice__title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #e65100;
  margin-bottom: 12rpx;
}

.footer-notice__text {
  display: block;
  font-size: 26rpx;
  color: #666666;
  line-height: 1.7;
}
